# ── Required ────────────────────────────────────────────────────────────
# Postgres superuser password used by the docker-compose `db` service.
POSTGRES_PASSWORD=change-me
# The exact URL you load the dashboard from (scheme + host + port).
# LAN example: http://192.168.1.50:3000 — your public domain once exposed.
# Form submissions are rejected as cross-site if this doesn't match.
ORIGIN=http://localhost:3000

# ── Signup captcha (required for signup to work at all) ─────────────────
# Cloudflare Turnstile keys (free). The captcha FAILS CLOSED: with these
# unset nobody can sign up. To try the app out, use Cloudflare's public
# always-pass TEST keys (below, commented) — swap in real keys before
# letting anyone else near it, since the test keys admit every bot.
#TURNSTILE_SITE_KEY=1x00000000000000000000AA
#TURNSTILE_SECRET_KEY=1x0000000000000000000000000000000AA
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ── Account email (required for other users; optional for just you) ─────
# Resend API key. Unset ⇒ verify/reset emails are logged to the container
# stdout instead of sent (grab links via `docker compose logs onwrist`).
RESEND_API_KEY=
# From-address for account emails (verify/reset/change).
MAIL_FROM=you@example.com

# ── Common options ──────────────────────────────────────────────────────
# Seeds one admin account at boot (idempotent, no-op once an admin exists).
# Set the initial password via the forgot-password flow (/reset) — no
# separate invite step.
ADMIN_EMAIL=
# How long a login lasts (sliding; renews with use).
SESSION_DAYS=30
# Optional: display name of the app (nav brand, page titles, PWA name).
APP_NAME=onwrist
# Max upload size (photo uploads). Default 25M.
BODY_SIZE_LIMIT=25M
# Photo storage root (fs driver).
DATA_DIR=./data

# ── Exposure / proxy hardening ──────────────────────────────────────────
# Interface the app port binds on. Default 0.0.0.0 (reachable from your
# network). Fronting it with a same-host proxy or Cloudflare tunnel? Set
# 127.0.0.1 so the proxy is the only way in — and set ADDRESS_HEADER.
#BIND_ADDRESS=0.0.0.0
# Header the app trusts for the client IP (per-IP rate limits). Empty
# (default) = the connecting socket's address — correct for direct access.
# Behind a proxy, set the header the proxy ALWAYS overwrites (cloudflared:
# CF-Connecting-IP) or all visitors share one rate-limit bucket. A
# configured-but-missing header 500s every request, so only set this when
# the proxy is really in front.
#ADDRESS_HEADER=CF-Connecting-IP

# ── Photos in S3 instead of local disk (optional) ───────────────────────
# S3-compatible photo storage (Backblaze B2, Cloudflare R2, MinIO, AWS).
# Leave all five unset to keep photos on local disk under DATA_DIR — the
# self-hosting default. Set all five (partial config fails at boot) to use
# a bucket instead. The bucket MUST be private: the app is its only reader
# and enforces per-user access; a public bucket would bypass that. Use a
# key scoped to this one bucket, never an account master key.
# B2 example: endpoint https://s3.us-west-004.backblazeb2.com, region us-west-004
#S3_ENDPOINT=
#S3_REGION=
#S3_BUCKET=
#S3_ACCESS_KEY_ID=
#S3_SECRET_ACCESS_KEY=

# DATABASE_URL is assembled by docker-compose from POSTGRES_PASSWORD; set it
# yourself only when running outside compose (e.g. npm run dev uses
# .env.scratch's value against the scratch stack).
#DATABASE_URL=postgres://onwrist:change-me@localhost:5432/onwrist
