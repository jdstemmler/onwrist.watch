# How long a login lasts (sliding; renews with use).
SESSION_DAYS=30
# The exact URL you load the dashboard from (scheme + host + port).
# LAN example: http://192.168.1.50:3000 — later, your tunnel domain.
# Form submissions are rejected as cross-site if this doesn't match.
ORIGIN=http://localhost:3000
DATA_DIR=./data
# Optional: display name of the app (nav brand, page titles, PWA name).
APP_NAME=onwrist
# Max upload size (photo uploads). Default 25M.
BODY_SIZE_LIMIT=25M
# Postgres superuser password used by the docker-compose `db` service.
POSTGRES_PASSWORD=change-me
# From-address for account emails (verify/reset/change).
MAIL_FROM=you@example.com
# Resend API key for sending account emails. Unset ⇒ emails are logged, not sent.
RESEND_API_KEY=
# Cloudflare Turnstile site/secret keys (bot check on signup). Unset ⇒ the
# captcha fails closed and nobody can sign up.
TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
# Seeds one admin account at boot (idempotent, no-op once an admin exists).
# Set the initial password via the forgot-password flow (/reset) — no
# separate invite step.
ADMIN_EMAIL=
# Which interface the app port binds on. Default 127.0.0.1 (compose): only
# the local cloudflared tunnel can reach it. LAN-only deploy without a
# tunnel? Set 0.0.0.0 — and clear ADDRESS_HEADER below.
#BIND_ADDRESS=127.0.0.1
# Header the app trusts for the client IP (rate limiting). Defaults to
# CF-Connecting-IP in compose, which is correct behind cloudflared and ONLY
# behind cloudflared. Not using Cloudflare? Set this empty or every request
# 500s (the adapter refuses a configured-but-missing header).
#ADDRESS_HEADER=CF-Connecting-IP
# DATABASE_URL is assembled by docker-compose from POSTGRES_PASSWORD; set it
# yourself only when running outside compose (e.g. npm run dev uses
# .env.scratch's value against the scratch stack).
#DATABASE_URL=postgres://onwrist:change-me@localhost:5432/onwrist
